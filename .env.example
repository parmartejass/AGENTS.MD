# Copy to `.env` in the repo root (or next to a tool that loads it). Gitignored.

# --- X / Twitter API — OAuth 2.0 ---
X_CLIENT_ID=
X_CLIENT_SECRET=
# Application-only bearer (from developer portal); not a user access token.
X_BEARER_TOKEN=

# --- X / Twitter API — OAuth 1.0a ---
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

