# Python bytecode / caches
__pycache__/
*.py[cod]

# Virtualenvs
.venv/
venv/

# Test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Template-generated outputs
templates/python-dual-entry/tests/output/*
!templates/python-dual-entry/tests/output/.gitkeep
templates/python-dual-entry/run-logs/

# OS / editor noise
.DS_Store
Thumbs.db

# Excel temp/lock files
~$*.xlsx
~$*.xlsm
~$*.xls
~$*.xlsb

# Environment files and tokens
.env
.x_token.json

# X-Bookmarks data (PII, large JSON, OAuth tokens)
X-Bookmarks Import/data/
X-Bookmarks Import/.x_token.json

# IDE settings
.vscode/
.idea/
.codex/config.toml
# Project-local Codex agent roles: tracked symlinks -> docs/agents/subagents/codex/
# (.codex/config.toml stays ignored: may contain machine-specific or secret-backed MCP config)
.agents/skills/
.cursor/skills/
.cursor/agents/
.cursor/plans/
.cursor/rules/
.cursor/mcp.json
.cursor/cli.json
# Claude Code runtime adapters: tracked (clone-and-go); use repo-relative symlinks. Local overrides:
.claude/settings.local.json
.mcp.json

# Logs
*.log

# App-specific outputs
*_DRYRUN_*.xlsb

# Session-analysis scratch context
.temp*/
