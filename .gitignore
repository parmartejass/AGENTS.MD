# Python bytecode / caches
__pycache__/
*.py[cod]

# Virtualenvs
.venv/
venv/

# Test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Template-generated outputs
templates/python-dual-entry/tests/output/*
!templates/python-dual-entry/tests/output/.gitkeep
templates/python-dual-entry/run-logs/

# OS / editor noise
.DS_Store
Thumbs.db

# Excel temp/lock files
~$*.xlsx
~$*.xlsm
~$*.xls
~$*.xlsb

# Environment files and tokens
.env
.x_token.json

# X-Bookmarks data (PII, large JSON, OAuth tokens)
X-Bookmarks Import/data/
X-Bookmarks Import/.x_token.json
# Duplicate of docs/agents/skills/x-api-data-access/ — use canonical skill bundle only
X-Bookmarks Import/skills/x-api-data-access/

# IDE settings
.vscode/
.idea/
.codex/config.toml
# Project-local Codex agent configs are local runtime state, not repo-owned projections.
# Do not commit a symlink-stub file named `.codex/agents` — on Windows it is a regular file and breaks Codex CLI (os error 267).
.codex/agents/
.agents/skills/
# Claude Code runtime adapters: tracked (clone-and-go); use repo-relative symlinks. Local overrides:
.claude/settings.local.json
.mcp.json

# Logs
*.log

# App-specific outputs
*_DRYRUN_*.xlsb

# Session-analysis scratch context
.temp*/
scripts/check_folder_architecture/.tmp-test-workspaces/
scripts/check_docs_router_contract/.tmp-test-workspaces/
